{
  "name": "restaurant-booking-z",
  "version": "1.0.0",
  "description": "AI-powered restaurant table reservation chatbot using LangGraph with structured outputs and conditional routing",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file .env src/index.ts",
    "dev": "node --watch --inspect --env-file .env src/index.ts",
    "test": "node --env-file .env --test tests/**/*.test.ts",
    "test:dev": "node --inspect --env-file .env --test --watch tests/**/*.test.ts",
    "test:e2e": "node --inspect --env-file .env --test tests/**/*e2e.test.ts",
    "test:e2e:dev": "node --inspect --env-file .env --test --watch tests/**/*e2e.test.ts",
    "langgraph:serve": "npx @langchain/langgraph-cli dev"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "restaurant",
    "reservation",
    "openrouter",
    "structured-outputs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@langchain/core": "^1.1.19",
    "@langchain/openai": "^1.2.5",
    "@openrouter/sdk": "^0.5.1",
    "fastify": "^5.7.4",
    "langchain": "^1.2.17"
  },
  "devDependencies": {
    "@types/node": "^24.10.12"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
